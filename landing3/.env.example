# Ejemplo de variables de entorno para La Ruta11
# Copiar a .env y completar con valores reales

# APIs de terceros
GOOGLE_MAPS_API_KEY=
WHATSAPP_API_TOKEN=
INSTAGRAM_API_KEY=
FACEBOOK_API_KEY=

# Cloudflare R2 para imágenes
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_BUCKET=laruta11-images
AWS_URL=https://pub-d6bf1ac3bcb0465cabadb9eeab426a65.r2.dev

# Base de datos
DB_HOST=localhost
DB_NAME=laruta11_db
DB_USER=
DB_PASS=

# Configuración de la aplicación
APP_URL=https://laruta11.cl
APP_ENV=production
DEBUG=false

# Email y SMTP
SMTP_HOST=
SMTP_USER=
SMTP_PASS=