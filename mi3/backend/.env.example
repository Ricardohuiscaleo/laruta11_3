APP_NAME=mi3
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api-mi3.laruta11.cl

DB_CONNECTION=mysql
DB_HOST=${APP_DB_HOST}
DB_PORT=3306
DB_DATABASE=${APP_DB_NAME}
DB_USERNAME=${APP_DB_USER}
DB_PASSWORD=${APP_DB_PASS}

SANCTUM_STATEFUL_DOMAINS=mi.laruta11.cl
SESSION_DOMAIN=.laruta11.cl

QUEUE_CONNECTION=database
CACHE_STORE=file

GMAIL_SENDER_EMAIL=saboresdelaruta11@gmail.com

# VAPID keys for Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Coolify API (for cronjob status dashboard)
COOLIFY_API_URL=http://76.13.126.63:8000
COOLIFY_API_TOKEN=

# Laravel Reverb (WebSocket server)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=api-mi3.laruta11.cl
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=9090

# AWS S3 (image storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=laruta11-images
