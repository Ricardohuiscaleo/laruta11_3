{
    "name": "laruta11/mi3-backend",
    "type": "project",
    "description": "mi3 RRHH Backend - Laravel 11 API",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "minishlink/web-push": "^9.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "giorgiosironi/eris": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
