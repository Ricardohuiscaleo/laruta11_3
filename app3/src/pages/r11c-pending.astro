---
---

<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pedido Confirmado - Crédito R11</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; min-height: 100vh; }
        .receipt { background: white; max-width: 100%; width: 100%; min-height: 100vh; }
        .receipt-content { padding: 20px; max-width: 500px; margin: 0 auto; }
        .header { text-align: center; padding: 30px 0 20px; border-bottom: 3px solid #10b981; margin-bottom: 20px; }
        .logo { font-size: 32px; font-weight: 900; color: #10b981; margin-bottom: 8px; letter-spacing: -1px; }
        .subtitle { font-size: 14px; color: #666; font-weight: 600; }
        .status-badge { background: #d1fae5; color: #065f46; padding: 12px 24px; border-radius: 25px; font-size: 13px; font-weight: 700; display: inline-block; margin: 20px 0; border: 2px solid #10b981; }
        .section { margin: 25px 0; padding: 20px 0; border-bottom: 2px dashed #e0e0e0; }
        .section:last-child { border-bottom: none; }
        .section-title { font-size: 12px; color: #10b981; text-transform: uppercase; font-weight: 700; letter-spacing: 1.5px; margin-bottom: 15px; }
        .info-row { display: flex; justify-content: space-between; align-items: flex-start; margin: 12px 0; font-size: 14px; gap: 10px; }
        .info-label { color: #666; font-weight: 600; min-width: 80px; }
        .info-value { color: #000; text-align: right; font-weight: 500; flex: 1; word-break: break-word; }
        .item { margin: 15px 0; padding: 15px; background: #f9f9f9; border-radius: 8px; border-left: 4px solid #10b981; }
        .item-header { display: flex; justify-content: space-between; font-weight: 700; font-size: 15px; margin-bottom: 8px; }
        .item-details { font-size: 12px; color: #666; margin: 6px 0; padding-left: 12px; line-height: 1.5; }
        .totals { margin-top: 25px; padding: 20px; background: #f9f9f9; border-radius: 12px; }
        .total-row { display: flex; justify-content: space-between; margin: 10px 0; font-size: 15px; font-weight: 500; }
        .total-row.discount { color: #059669; font-weight: 600; }
        .total-row.final { font-size: 22px; font-weight: 900; margin-top: 20px; padding-top: 20px; border-top: 3px solid #10b981; color: #10b981; }
        .credit-info { background: #ecfdf5; padding: 16px; border-radius: 12px; margin: 25px 0; border: 3px solid #10b981; text-align: center; }
        .credit-info-title { font-weight: 700; color: #065f46; margin-bottom: 8px; font-size: 14px; }
        .credit-info-detail { font-size: 12px; color: #047857; }
        .actions { margin-top: 30px; padding-bottom: 20px; }
        .btn { display: flex; align-items: center; justify-content: center; gap: 12px; width: 100%; padding: 18px; border: none; border-radius: 12px; font-weight: 700; font-size: 16px; cursor: pointer; transition: all 0.2s; text-decoration: none; margin-bottom: 12px; }
        .btn-primary { background: #10b981; color: white; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); }
        .btn-primary:active { transform: scale(0.98); }
        .footer { text-align: center; margin-top: 30px; padding: 25px 0; border-top: 2px dashed #e0e0e0; font-size: 12px; color: #999; line-height: 1.6; }
        .hidden { display: none; }
        @media (min-width: 768px) { body { padding: 20px; } .receipt { border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); min-height: auto; } }
    </style>
    <link rel="icon" type="image/x-icon" href="/icon.ico" />
</head>
<body>
    <div class="receipt">
        <div class="receipt-content">
            <div class="header">
                <div class="logo"><img src="/icon.ico" style="width:32px;height:32px;vertical-align:middle;margin-right:8px;" alt="Logo"> LA RUTA 11</div>
                <div class="subtitle">Comprobante de Pedido</div>
                <div class="status-badge">✅ Pagado con Crédito R11</div>
            </div>
            <div class="section">
                <div class="section-title">Número de Pedido</div>
                <div style="text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;" id="order-id">-</div>
            </div>
            <div id="customer-info" class="section hidden">
                <div class="section-title">Datos del Cliente</div>
                <div class="info-row"><span class="info-label">Cliente:</span><span class="info-value" id="customer-name">-</span></div>
                <div class="info-row"><span class="info-label">Teléfono:</span><span class="info-value" id="customer-phone">-</span></div>
                <div class="info-row"><span class="info-label">Entrega:</span><span class="info-value" id="delivery-type">-</span></div>
                <div id="delivery-address-row" class="info-row hidden"><span class="info-label">Dirección:</span><span class="info-value" id="delivery-address">-</span></div>
                <div id="customer-notes-row" class="info-row hidden"><span class="info-label">Notas:</span><span class="info-value" id="customer-notes">-</span></div>
            </div>
            <div class="section">
                <div class="section-title">Productos</div>
                <div id="order-items"><p style="color:#999;font-size:13px;">Cargando...</p></div>
            </div>
            <div class="totals">
                <div id="product-discount-row" class="total-row discount hidden"><span>🍔 Descuento 10% R11:</span><span id="product-discount">-$0</span></div>
                <div class="total-row"><span>Subtotal:</span><span id="subtotal">$0</span></div>
                <div id="delivery-row" class="total-row hidden"><span>Delivery:</span><span id="delivery-fee">$0</span></div>
                <div class="total-row final"><span>TOTAL:</span><span id="total">$0</span></div>
            </div>
            <div class="credit-info">
                <div class="credit-info-title">✅ Pagado con Crédito R11</div>
                <div class="credit-info-detail">Descuento automático de tu sueldo</div>
            </div>
            <div class="actions">
                <a href="/" class="btn btn-primary">← Volver al Menú</a>
            </div>
            <div class="footer">
                <p>Comprobante digital - La Ruta 11</p>
                <p style="margin-top:5px;">Tu pedido ya está en preparación 🍔</p>
            </div>
        </div>
    </div>

    <script>
        const urlParams = new URLSearchParams(window.location.search);
        const orderId = urlParams.get('order');
        
        if (orderId) {
            document.getElementById('order-id').textContent = orderId;
        }

        async function loadOrderData() {
            if (!orderId) return;
            try {
                const response = await fetch(`/api/get_order.php?order_id=${orderId}`);
                const data = await response.json();
                if (data.success && data.order) {
                    const order = data.order;
                    
                    // Customer info
                    const infoSection = document.getElementById('customer-info');
                    infoSection.classList.remove('hidden');
                    document.getElementById('customer-name').textContent = order.customer_name || '-';
                    document.getElementById('customer-phone').textContent = order.customer_phone || '-';
                    document.getElementById('delivery-type').textContent = order.delivery_type === 'delivery' ? '🚴 Delivery' : '🏪 Retiro en local';
                    
                    if (order.delivery_type === 'delivery' && order.delivery_address) {
                        document.getElementById('delivery-address-row').classList.remove('hidden');
                        document.getElementById('delivery-address').textContent = order.delivery_address;
                    }
                    if (order.customer_notes) {
                        document.getElementById('customer-notes-row').classList.remove('hidden');
                        document.getElementById('customer-notes').textContent = order.customer_notes;
                    }

                    // Items
                    const itemsEl = document.getElementById('order-items');
                    if (order.items && order.items.length > 0) {
                        itemsEl.innerHTML = order.items.map(item => {
                            let details = '';
                            if (item.customizations && item.customizations.length > 0) {
                                details = `<div class="item-details" style="color:#10b981;">+ ${item.customizations.map(c => `${c.quantity}x ${c.name}`).join(', ')}</div>`;
                            }
                            return `<div class="item"><div class="item-header"><span>${item.quantity}x ${item.name}</span><span>$${(item.price * item.quantity).toLocaleString('es-CL')}</span></div>${details}</div>`;
                        }).join('');
                    }

                    // Totals
                    const discount = parseFloat(order.discount_amount || 0);
                    const subtotal = parseFloat(order.subtotal || 0);
                    const deliveryFee = parseFloat(order.delivery_fee || 0);
                    const total = parseFloat(order.total || 0);

                    if (discount > 0) {
                        document.getElementById('product-discount-row').classList.remove('hidden');
                        document.getElementById('product-discount').textContent = `-$${discount.toLocaleString('es-CL')}`;
                    }
                    document.getElementById('subtotal').textContent = `$${(subtotal - discount).toLocaleString('es-CL')}`;
                    if (deliveryFee > 0) {
                        document.getElementById('delivery-row').classList.remove('hidden');
                        document.getElementById('delivery-fee').textContent = `$${deliveryFee.toLocaleString('es-CL')}`;
                    }
                    document.getElementById('total').textContent = `$${total.toLocaleString('es-CL')}`;
                }
            } catch (e) {
                console.error('Error loading order:', e);
            }
        }

        loadOrderData();
    </script>
</body>
</html>
