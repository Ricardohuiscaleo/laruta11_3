---
const user_id = Astro.url.searchParams.get('user_id');
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Estado de Cuenta - La Ruta 11</title>
</head>
<body class="bg-gray-50">
    <div class="max-w-4xl mx-auto p-4 md:p-6">
        <div id="loading" class="text-center py-20">
            <div class="animate-spin w-12 h-12 border-4 border-orange-500 border-t-transparent rounded-full mx-auto"></div>
            <p class="text-gray-600 mt-4">Cargando estado de cuenta...</p>
        </div>

        <div id="content" class="hidden">
            <div class="bg-white rounded-lg shadow-md p-6 mb-6">
                <div class="flex items-center justify-between mb-4">
                    <button onclick="window.history.back()" class="text-orange-600 hover:text-orange-700 font-semibold flex items-center gap-1">
                        <span>←</span> Volver
                    </button>
                    <img src={`https://pub-d6bf1ac3bcb0465cabadb9eeab426a65.r2.dev/WhatsApp%20Image%202026-05-20%20at%2019.50.28.jpeg`} alt="La Ruta 11" class="w-16 h-16">
                    <div class="text-right">
                        <h1 class="text-2xl font-bold text-gray-800">Estado de Cuenta</h1>
                        <p class="text-sm text-gray-600">Crédito RL6</p>
                    </div>
                </div>
                
                <div class="border-t pt-4">
                    <h2 id="userName" class="text-xl font-bold text-gray-800"></h2>
                    <p id="userInfo" class="text-sm text-gray-600"></p>
                    <p id="userEmail" class="text-sm text-gray-500"></p>
                </div>
            </div>

            <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-4 mb-6">
                <h3 class="text-sm font-semibold text-gray-700 mb-3">📊 Resumen de Crédito</h3>
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-gray-50 border border-gray-200 rounded p-3">
                        <p class="text-xs text-gray-500 mb-1">Crédito Total</p>
                        <p id="creditoTotal" class="text-xl font-bold text-gray-800"></p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 rounded p-3">
                        <p class="text-xs text-gray-500 mb-1">Consumido</p>
                        <p id="creditoUsado" class="text-xl font-bold text-yellow-600"></p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 rounded p-3">
                        <p class="text-xs text-gray-500 mb-1">Disponible</p>
                        <p id="creditoDisponible" class="text-xl font-bold text-green-600"></p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 rounded p-3">
                        <p class="text-xs text-gray-500 mb-1">Saldo a Pagar</p>
                        <p id="saldoPagar" class="text-xl font-bold text-red-600"></p>
                    </div>
                </div>
                
                <div id="transferButton" class="hidden mt-3">
                    <button
                        id="btnShowTransfer"
                        class="w-full bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold py-3 px-6 rounded-lg hover:from-blue-600 hover:to-blue-700 transition-all shadow-md flex items-center justify-center gap-2"
                    >
                        <span style="font-size: 20px;">🏦</span>
                        <span>Pagar con Transferencia</span>
                    </button>
                </div>

                <div id="transferForm" class="hidden mt-3 border border-emerald-200 rounded-lg p-4 bg-emerald-50">
                    <h4 class="text-sm font-bold text-emerald-800 mb-3">Subir Comprobante de Transferencia</h4>
                    <p class="text-xs text-emerald-600 mb-3">Transfiere al mismo monto y sube el comprobante. Lo revisaremos y aprobaremos a la brevedad.</p>

                    <div class="bg-white border border-emerald-300 rounded-lg p-3 mb-4 text-xs space-y-1.5">
                        <p class="font-semibold text-emerald-800 mb-2">📋 Datos para transferencia:</p>
                        <div class="flex justify-between"><span class="text-gray-600">Banco:</span><span class="font-medium">BCI</span></div>
                        <div class="flex justify-between"><span class="text-gray-600">Titular:</span><span class="font-medium">La Ruta once Spa</span></div>
                        <div class="flex justify-between"><span class="text-gray-600">RUT:</span><span class="font-medium">78.194.739-3</span></div>
                        <div class="flex justify-between"><span class="text-gray-600">Cuenta:</span><span class="font-medium">97618110</span></div>
                        <div class="flex justify-between"><span class="text-gray-600">Email:</span><span class="font-medium">saboresdelaruta11@gmail.com</span></div>
                        <button onclick="copiarDatosTransferencia()" class="mt-2 w-full bg-emerald-100 hover:bg-emerald-200 text-emerald-800 font-semibold py-2 px-3 rounded-lg transition-colors flex items-center justify-center gap-1.5 border border-emerald-200">
                            <span id="copyIcon">📋</span>
                            <span id="copyText">Copiar datos</span>
                        </button>
                    </div>

                    <label class="block text-xs font-semibold text-gray-700 mb-1">Monto a pagar</label>
                    <p id="transferAmount" class="text-2xl font-bold text-gray-800 mb-3"></p>

                    <label class="block text-xs font-semibold text-gray-700 mb-1">Comprobante (JPG, PNG, PDF)</label>
                    <input id="receiptFile" type="file" accept=".jpg,.jpeg,.png,.webp,.pdf" class="w-full text-sm mb-3 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-emerald-100 file:text-emerald-700 hover:file:bg-emerald-200" />

                    <div id="transferStatus" class="hidden text-sm mb-3"></div>

                    <button
                        id="btnSubmitTransfer"
                        class="w-full bg-emerald-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-emerald-700 transition-all shadow-sm flex items-center justify-center gap-2 disabled:opacity-50"
                    >
                        Subir Comprobante
                    </button>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-bold text-gray-800">📋 Historial de Transacciones</h3>
                    <span id="totalTx" class="text-sm text-gray-600"></span>
                </div>
                
                <div id="transactions" class="space-y-3"></div>
                
                <div id="noTransactions" class="hidden text-center py-8 text-gray-400">
                    No hay transacciones registradas
                </div>
            </div>

            <div class="mt-6 text-center text-sm text-gray-500">
                <p>📍 Yumbel 2629, Arica, Chile</p>
                <p>📞 Ventas: +56 9 3622 7422 | 🛠️ Soporte: +56 9 4539 2581</p>
                <p>📧 saboresdelaruta11@gmail.com</p>
                <p class="mt-2">© {new Date().getFullYear()} La Ruta 11 SpA</p>
            </div>
        </div>
    </div>

    <script define:vars={{ serverUserId: user_id }}>
        function getUserIdFromUrl() {
            const params = new URLSearchParams(window.location.search);
            return params.get('user_id');
        }
        
        let userId = serverUserId || getUserIdFromUrl();
        
        async function getUserId() {
            if (userId) return userId;
            
            try {
                const response = await fetch('/api/auth/check_session.php');
                const data = await response.json();
                
                if (data.authenticated && data.user && data.user.id) {
                    return data.user.id;
                }
                return null;
            } catch (e) {
                console.error('Error obteniendo sesión:', e);
                return null;
            }
        }
        
        async function init() {
            userId = await getUserId();
            
            if (!userId) {
                alert('Debes iniciar sesión para ver tu estado de cuenta');
                document.getElementById('loading').innerHTML = '<p class="text-red-600">Error: Debes iniciar sesión</p>';
                setTimeout(() => window.location.href = '/', 2000);
            } else {
                loadStatement(userId);
            }
        }
        
        init();
        
        // ─── Copiar datos transferencia ───
        function copiarDatosTransferencia() {
            const texto = [
                'Banco: BCI',
                'Titular: La Ruta once Spa',
                'RUT: 78.194.739-3',
                'Cuenta Corriente: 97618110',
                'Email: saboresdelaruta11@gmail.com',
                '',
                'Monto: ' + (document.getElementById('transferAmount')?.textContent || '[ingresa el monto]'),
            ].join('\n');

            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(texto).then(() => {
                    const icon = document.getElementById('copyIcon');
                    const txt = document.getElementById('copyText');
                    if (icon) icon.textContent = '✅';
                    if (txt) txt.textContent = 'Copiado';
                    setTimeout(() => {
                        if (icon) icon.textContent = '📋';
                        if (txt) txt.textContent = 'Copiar datos';
                    }, 3000);
                }).catch(() => {
                    fallbackCopy(texto);
                });
            } else {
                fallbackCopy(texto);
            }
        }

        function fallbackCopy(text) {
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            const icon = document.getElementById('copyIcon');
            const txt = document.getElementById('copyText');
            if (icon) icon.textContent = '✅';
            if (txt) txt.textContent = 'Copiado';
            setTimeout(() => {
                if (icon) icon.textContent = '📋';
                if (txt) txt.textContent = 'Copiar datos';
            }, 3000);
        }
        
        // ─── Transferencia ───
        async function pagarConTransferencia() {
            const fileInput = document.getElementById('receiptFile');
            const amountInput = document.getElementById('transferAmount');
            const statusDiv = document.getElementById('transferStatus');
            const btn = document.getElementById('btnSubmitTransfer');

            if (!fileInput.files || fileInput.files.length === 0) {
                statusDiv.className = 'text-sm mb-3 text-red-600';
                statusDiv.textContent = 'Selecciona un comprobante';
                statusDiv.classList.remove('hidden');
                return;
            }
            const rawMonto = (amountInput.textContent || '').replace(/[$.]/g, '');
            if (!rawMonto || Number(rawMonto) <= 0) {
                statusDiv.className = 'text-sm mb-3 text-red-600';
                statusDiv.textContent = 'Ingresa un monto válido';
                statusDiv.classList.remove('hidden');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin">⏳</span> Subiendo...';
            statusDiv.className = 'hidden';

            const formData = new FormData();
            formData.append('user_id', userId);
            formData.append('monto', (amountInput.textContent || '').replace(/[$.]/g, ''));
            formData.append('tipo', 'rl6');
            formData.append('receipt', fileInput.files[0]);

            try {
                const resp = await fetch('https://app.laruta11.cl/api/payments/upload_receipt.php', {
                    method: 'POST',
                    body: formData
                });
                const data = await resp.json();

                if (data.success) {
                    statusDiv.className = 'text-sm mb-3 text-green-700 bg-green-100 rounded-lg p-3';
                    statusDiv.innerHTML = '✅ Comprobante recibido. Queda en revisión. Te notificaremos cuando esté aprobado.';
                    statusDiv.classList.remove('hidden');
                    fileInput.value = '';
                    btn.innerHTML = 'Subir Comprobante';
                    btn.disabled = false;
                } else {
                    throw new Error(data.error || 'Error al subir comprobante');
                }
            } catch (err) {
                statusDiv.className = 'text-sm mb-3 text-red-600';
                statusDiv.textContent = 'Error: ' + err.message;
                statusDiv.classList.remove('hidden');
                btn.innerHTML = 'Subir Comprobante';
                btn.disabled = false;
            }
        }

        // Show transfer form
        document.addEventListener('DOMContentLoaded', function() {
            const btnShow = document.getElementById('btnShowTransfer');
            const form = document.getElementById('transferForm');
            const btnSubmit = document.getElementById('btnSubmitTransfer');

            if (btnShow) {
                btnShow.addEventListener('click', function() {
                    form.classList.remove('hidden');
                });
            }
            if (btnSubmit) {
                btnSubmit.addEventListener('click', pagarConTransferencia);
            }
        });
        
        async function loadStatement(uid) {
            try {
                const response = await fetch(`https://app.laruta11.cl/api/rl6/get_statement.php?user_id=${uid}`);
                const data = await response.json();
                
                if (!data.success) {
                    alert('Error: ' + data.error);
                    return;
                }

                const { user, transactions } = data;

                document.getElementById('userName').textContent = user.nombre;
                document.getElementById('userInfo').textContent = `${user.grado_militar} - ${user.unidad_trabajo}`;
                document.getElementById('userEmail').textContent = user.email;

                document.getElementById('creditoTotal').textContent = '$' + user.credito_total.toLocaleString('es-CL');
                document.getElementById('creditoUsado').textContent = '$' + user.credito_usado.toLocaleString('es-CL');
                document.getElementById('creditoDisponible').textContent = '$' + user.credito_disponible.toLocaleString('es-CL');
                document.getElementById('saldoPagar').textContent = '$' + user.credito_usado.toLocaleString('es-CL');
                document.getElementById('transferAmount').textContent = '$' + user.credito_usado.toLocaleString('es-CL');
                
                // Mostrar botón de transferencia si hay saldo pendiente
                if (user.credito_usado > 0) {
                    document.getElementById('transferButton').classList.remove('hidden');
                }

                document.getElementById('totalTx').textContent = `${transactions.length} transacciones`;
                
                if (transactions.length === 0) {
                    document.getElementById('noTransactions').classList.remove('hidden');
                } else {
                    const container = document.getElementById('transactions');
                    
                    // Ordenar por fecha (más antiguas primero)
                    const sorted = [...transactions].sort((a, b) => new Date(a.fecha) - new Date(b.fecha));
                    
                    container.innerHTML = sorted.map(tx => {
                        const fecha = new Date(tx.fecha);
                        const meses = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
                        const fechaStr = fecha.getDate() + ' ' + meses[fecha.getMonth()];
                        
                        const isRefund = tx.tipo === 'refund';
                        const monto = Math.round(tx.monto);
                        
                        let itemsHtml = '';
                        if (tx.items && tx.items.length > 0) {
                            itemsHtml = '<div class="mt-2 text-xs text-gray-600">' + tx.items.map(item => 
                                item.cantidad + 'x ' + item.nombre
                            ).join(' • ') + '</div>';
                        }
                        
                        const subtotalProd = tx.subtotal_productos || 0;
                        const deliveryFee = tx.delivery_fee || 0;
                        const deliveryDiscount = tx.delivery_discount || 0;
                        const extras = monto - subtotalProd - deliveryFee + deliveryDiscount;
                        
                        let resumenHtml = '';
                        if (!isRefund && monto > 0) {
                            resumenHtml = '<div class="mt-2 pt-2 border-t border-gray-100 text-xs space-y-1">';
                            if (subtotalProd > 0) resumenHtml += '<div class="flex justify-between text-gray-600"><span>Subtotal pedidos:</span><span>$' + Math.round(subtotalProd).toLocaleString('es-CL') + '</span></div>';
                            if (extras > 0) resumenHtml += '<div class="flex justify-between text-gray-600"><span>Extras/Customizaciones:</span><span>$' + Math.round(extras).toLocaleString('es-CL') + '</span></div>';
                            if (deliveryFee > 0) resumenHtml += '<div class="flex justify-between text-gray-600"><span>Delivery:</span><span>$' + Math.round(deliveryFee).toLocaleString('es-CL') + '</span></div>';
                            if (deliveryDiscount > 0) resumenHtml += '<div class="flex justify-between text-green-600"><span>Descuento delivery:</span><span>-$' + Math.round(deliveryDiscount).toLocaleString('es-CL') + '</span></div>';
                            resumenHtml += '<div class="flex justify-between font-semibold text-orange-600"><span>Total:</span><span>$' + Math.round(monto).toLocaleString('es-CL') + '</span></div></div>';
                        }
                        
                        const montoDisplay = '<div class="text-right"><span class="text-lg font-bold ' + (isRefund ? 'text-green-600' : 'text-red-600') + '">' + (isRefund ? '+' : '-') + '$' + monto.toLocaleString('es-CL') + '</span></div>';
                        
                        return '<div class="bg-white border-l-4 ' + (isRefund ? 'border-green-400' : 'border-red-400') + ' border-r border-t border-b border-gray-200 rounded p-3"><div class="flex justify-between items-start mb-2"><div><span class="text-sm font-semibold text-gray-800">' + fechaStr + '</span><p class="text-xs text-gray-500 mt-1">' + tx.descripcion + '</p></div>' + montoDisplay + '</div><p class="text-xs text-gray-500">Orden #' + (tx.order_id || tx.id) + '</p>' + itemsHtml + resumenHtml + '</div>';
                    }).join('');
                    
                    // Resumen General - Calcular directamente de credito_usado
                    const totalGeneral = user.credito_usado;
                    
                    container.innerHTML += '<div class="mt-6 pt-4 border-t-2 border-gray-300 bg-gray-50 rounded-lg p-4"><h4 class="text-sm font-bold text-gray-700 mb-3">Resumen General</h4><div class="space-y-2 text-sm"><div class="flex justify-between text-lg font-bold text-orange-600"><span>Total a Pagar:</span><span>$' + Math.round(totalGeneral).toLocaleString('es-CL') + '</span></div><p class="text-xs text-gray-500 mt-2">Este monto refleja tu saldo actual de crédito usado</p></div></div>';
                }

                document.getElementById('loading').classList.add('hidden');
                document.getElementById('content').classList.remove('hidden');
            } catch (error) {
                alert('Error al cargar estado de cuenta');
                console.error(error);
            }
        }
    </script>

    <style>
