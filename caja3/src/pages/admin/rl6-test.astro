---
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RL6 Test - La Ruta 11</title>
</head>
<body class="bg-gray-50 min-h-screen">
    <header class="bg-white border-b shadow-sm sticky top-0 z-40">
        <div class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
            <div>
                <h1 class="text-xl font-bold text-gray-900">🧪 RL6 Test</h1>
                <p class="text-xs text-gray-500">Simular solicitud de crédito militar</p>
            </div>
            <a href="/admin/emails" class="text-sm text-orange-600 hover:underline">← Volver</a>
        </div>
    </header>

    <main class="max-w-2xl mx-auto px-4 py-6 space-y-4">

        <!-- Formulario -->
        <div class="bg-white rounded-xl border shadow-sm p-6">
            <h2 class="text-base font-semibold text-gray-900 mb-4">Datos del Militar (simulados)</h2>
            <div class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Nombre</label>
                        <input id="nombre" type="text" value="Juan Pérez Test"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Email</label>
                        <input id="email" type="email" value="test@laruta11.cl"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">RUT</label>
                        <input id="rut" type="text" value="12.345.678-9"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Grado Militar</label>
                        <input id="grado" type="text" value="Cabo Primero"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Unidad de Trabajo</label>
                    <input id="unidad" type="text" value="Regimiento Logístico N°6"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                </div>
                <div>
                    <label class="block text-xs font-medium text-gray-600 mb-1">Domicilio</label>
                    <input id="domicilio" type="text" value="Av. Ejemplo 123, Iquique"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                </div>
            </div>
        </div>

        <!-- Botones -->
        <div class="flex gap-3">
            <button id="btnEnviar"
                class="flex-1 bg-orange-600 hover:bg-orange-700 text-white font-semibold py-3 rounded-xl transition-colors text-sm">
                📤 Enviar Solicitud de Prueba
            </button>
            <button id="btnEliminar" disabled
                class="flex-1 bg-red-500 hover:bg-red-600 disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold py-3 rounded-xl transition-colors text-sm">
                🗑️ Eliminar Registro
            </button>
        </div>

        <!-- Resultado -->
        <div id="resultado" class="hidden"></div>

    </main>

    <script>
        let lastUserId = null;

        const btnEnviar  = document.getElementById('btnEnviar');
        const btnEliminar = document.getElementById('btnEliminar');
        const resultado  = document.getElementById('resultado');

        function showResult(html, type = 'info') {
            const colors = {
                success: 'bg-green-50 border border-green-200 text-green-800',
                error:   'bg-red-50 border border-red-200 text-red-800',
                info:    'bg-blue-50 border border-blue-200 text-blue-800',
            };
            resultado.className = `rounded-xl p-4 text-sm ${colors[type]}`;
            resultado.innerHTML = html;
            resultado.classList.remove('hidden');
        }

        btnEnviar.addEventListener('click', async () => {
            btnEnviar.disabled = true;
            btnEnviar.textContent = '⏳ Enviando...';

            const body = new FormData();
            body.append('nombre',    document.getElementById('nombre').value);
            body.append('email',     document.getElementById('email').value);
            body.append('rut',       document.getElementById('rut').value);
            body.append('grado',     document.getElementById('grado').value);
            body.append('unidad',    document.getElementById('unidad').value);
            body.append('domicilio', document.getElementById('domicilio').value);

            try {
                const res  = await fetch('https://app.laruta11.cl/api/rl6/test_send_rl6.php', { method: 'POST', body });
                const data = await res.json();

                if (data.success) {
                    lastUserId = data.user_id;
                    btnEliminar.disabled = false;
                    showResult(`
                        <p class="font-semibold mb-1">✅ Solicitud enviada</p>
                        <p>Usuario ID: <strong>${data.user_id}</strong></p>
                        <p>Telegram: ${data.telegram_sent ? '✅ Mensaje enviado' : '⚠️ No enviado'}</p>
                        <p class="mt-2 text-xs text-green-600">Revisa el bot de Telegram para aprobar/rechazar.</p>
                    `, 'success');
                } else {
                    showResult(`<p class="font-semibold">❌ Error</p><p>${data.error}</p>`, 'error');
                }
            } catch (e) {
                showResult(`<p class="font-semibold">❌ Error de conexión</p><p>${e.message}</p>`, 'error');
            }

            btnEnviar.disabled = false;
            btnEnviar.textContent = '📤 Enviar Solicitud de Prueba';
        });

        btnEliminar.addEventListener('click', async () => {
            if (!lastUserId) return;
            if (!confirm(`¿Eliminar el usuario de prueba ID ${lastUserId}?`)) return;

            btnEliminar.disabled = true;
            btnEliminar.textContent = '⏳ Eliminando...';

            try {
                const body = new FormData();
                body.append('user_id', lastUserId);
                const res  = await fetch('https://app.laruta11.cl/api/rl6/delete_test_rl6.php', { method: 'POST', body });
                const data = await res.json();

                if (data.success) {
                    lastUserId = null;
                    btnEliminar.disabled = true;
                    showResult(`<p class="font-semibold">🗑️ Registro eliminado correctamente.</p>`, 'info');
                } else {
                    showResult(`<p class="font-semibold">❌ Error al eliminar</p><p>${data.error}</p>`, 'error');
                    btnEliminar.disabled = false;
                }
            } catch (e) {
                showResult(`<p class="font-semibold">❌ Error de conexión</p><p>${e.message}</p>`, 'error');
                btnEliminar.disabled = false;
            }

            btnEliminar.textContent = '🗑️ Eliminar Registro';
        });
    </script>
</body>
</html>
