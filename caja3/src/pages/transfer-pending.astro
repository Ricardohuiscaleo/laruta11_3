<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transferencia Pendiente - La Ruta 11</title>
    <style>
        .bg-gray-50 { background-color: #f9fafb; }
        .font-sans { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif; }
        .min-h-screen { min-height: 100vh; }
        .flex { display: flex; }
        .items-center { align-items: center; }
        .justify-center { justify-content: center; }
        .p-4 { padding: 1rem; }
        .max-w-md { max-width: 28rem; }
        .w-full { width: 100%; }
        .bg-white { background-color: #ffffff; }
        .rounded-lg { border-radius: 0.5rem; }
        .shadow-xl { box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); }
        .p-8 { padding: 2rem; }
        .text-center { text-align: center; }
        .mb-6 { margin-bottom: 1.5rem; }
        .w-16 { width: 4rem; }
        .h-16 { height: 4rem; }
        .bg-amber-100 { background-color: #fef3c7; }
        .rounded-full { border-radius: 9999px; }
        .mx-auto { margin-left: auto; margin-right: auto; }
        .mb-4 { margin-bottom: 1rem; }
        .w-8 { width: 2rem; }
        .h-8 { height: 2rem; }
        .text-amber-600 { color: #d97706; }
        .text-2xl { font-size: 1.5rem; line-height: 2rem; }
        .font-bold { font-weight: 700; }
        .text-gray-900 { color: #111827; }
        .mb-2 { margin-bottom: 0.5rem; }
        .text-gray-600 { color: #4b5563; }
        .bg-amber-50 { background-color: #fffbeb; }
        .border { border-width: 1px; }
        .border-amber-200 { border-color: #fde68a; }
        .font-semibold { font-weight: 600; }
        .text-amber-800 { color: #92400e; }
        .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
        .text-amber-700 { color: #b45309; }
        .bg-blue-50 { background-color: #eff6ff; }
        .border-blue-200 { border-color: #bfdbfe; }
        .text-blue-800 { color: #1e40af; }
        .space-y-1 > * + * { margin-top: 0.25rem; }
        .border-gray-200 { border-color: #e5e7eb; }
        .mb-3 { margin-bottom: 0.75rem; }
        .border-t { border-top-width: 1px; }
        .pt-3 { padding-top: 0.75rem; }
        .mt-3 { margin-top: 0.75rem; }
        .justify-between { justify-content: space-between; }
        .hidden { display: none; }
        .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
        .pt-2 { padding-top: 0.5rem; }
        .text-emerald-600 { color: #059669; }
        .space-y-3 > * + * { margin-top: 0.75rem; }
        .bg-emerald-600 { background-color: #059669; }
        .hover\:bg-emerald-700:hover { background-color: #047857; }
        .text-white { color: #ffffff; }
        .py-3 { padding-top: 0.75rem; padding-bottom: 0.75rem; }
        .px-4 { padding-left: 1rem; padding-right: 1rem; }
        .gap-2 { gap: 0.5rem; }
        .transition-colors { transition-property: color, background-color, border-color, text-decoration-color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
        .w-5 { width: 1.25rem; }
        .h-5 { height: 1.25rem; }
        .bg-gray-600 { background-color: #4b5563; }
        .hover\:bg-gray-700:hover { background-color: #374151; }
        .text-xs { font-size: 0.75rem; line-height: 1rem; }
        .text-gray-500 { color: #6b7280; }
        .mt-6 { margin-top: 1.5rem; }
        .font-mono { font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas, "Liberation Mono", Menlo, monospace; }
        .text-red-500 { color: #ef4444; }
        .mt-1 { margin-top: 0.25rem; }
        .border-b { border-bottom-width: 1px; }
        .pb-2 { padding-bottom: 0.5rem; }
        .last\:border-b-0:last-child { border-bottom-width: 0; }
        .last\:mb-0:last-child { margin-bottom: 0; }
        .items-start { align-items: flex-start; }
        .font-medium { font-weight: 500; }
    </style>
    <link rel="icon" type="image/png" href="/icon.png">
</head>
<body class="bg-gray-50 font-sans">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="max-w-md w-full bg-white rounded-lg shadow-xl p-8">
            <div class="mb-6 text-center">
                <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-gray-900 mb-2">Pago Pendiente</h1>
                <p class="text-gray-600 mb-6">Tu pedido está esperando confirmación de transferencia</p>
            </div>



            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                <h3 class="font-semibold text-blue-800 mb-2">💳 Datos para Transferencia</h3>
                <div class="text-sm text-blue-800 space-y-1">
                    <p><strong>Titular:</strong> La Ruta once Spa</p>
                    <p><strong>RUT:</strong> 78.194.739-3</p>
                    <p><strong>Banco:</strong> Banco BCI</p>
                    <p><strong>Cuenta Corriente:</strong> 97618110</p>
                    <p><strong>Email:</strong> SABORESDELARUTA11@GMAIL.COM</p>
                </div>
            </div>

            <!-- Datos del Cliente -->
            <div id="customer-info" class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6 hidden">
                <h3 class="font-semibold text-green-800 mb-2">👤 Datos del Cliente</h3>
                <div class="text-sm text-green-800 space-y-1">
                    <p><strong>Cliente:</strong> <span id="customer-name">-</span></p>
                    <p><strong>Teléfono:</strong> <span id="customer-phone">-</span></p>
                    <p><strong>Tipo de entrega:</strong> <span id="delivery-type">-</span></p>
                    <p id="delivery-address-row" class="hidden"><strong>Dirección:</strong> <span id="delivery-address">-</span></p>
                </div>
            </div>

            <!-- Tu Pedido -->
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
                <h3 class="font-semibold text-gray-900 mb-3">🛒 Tu Pedido</h3>
                <div id="order-items">
                    <!-- Los items se cargarán dinámicamente -->
                </div>
                <div class="border-t border-gray-200 pt-3 mt-3">
                    <div class="flex justify-between mb-2">
                        <span class="text-gray-600">Subtotal:</span>
                        <span id="subtotal" class="font-semibold">$0</span>
                    </div>
                    <div id="delivery-row" class="justify-between mb-2 hidden">
                        <span class="text-gray-600">Delivery:</span>
                        <span id="delivery-fee" class="font-semibold">$0</span>
                    </div>
                    <div id="discount-10-row" class="justify-between mb-2 hidden">
                        <span class="text-green-600">⭐ Descuento 10%:</span>
                        <span id="discount-10" class="font-semibold text-green-600">$0</span>
                    </div>
                    <div id="discount-30-row" class="justify-between mb-2 hidden">
                        <span class="text-yellow-600">⭐ Descuento 30%:</span>
                        <span id="discount-30" class="font-semibold text-yellow-600">$0</span>
                    </div>
                    <div id="discount-birthday-row" class="justify-between mb-2 hidden">
                        <span class="text-pink-600">🎂 Descuento Cumpleaños:</span>
                        <span id="discount-birthday" class="font-semibold text-pink-600">$0</span>
                    </div>
                    <div id="discount-pizza-row" class="justify-between mb-2 hidden">
                        <span class="text-orange-600">🍕 Descuento Pizza:</span>
                        <span id="discount-pizza" class="font-semibold text-orange-600">$0</span>
                    </div>
                    <div class="flex justify-between text-lg font-bold border-t border-gray-200 pt-2">
                        <span>Total:</span>
                        <span id="total" class="text-emerald-600">$0</span>
                    </div>
                </div>
            </div>

            <div class="space-y-3">
                <button 
                    onclick="window.location.href='https://caja.laruta11.cl'"
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 px-4 rounded-lg transition-colors"
                >
                    Volver a Caja
                </button>
            </div>

            <div class="text-xs text-gray-500 mt-6 space-y-1 text-center">
                <p>Pedido: <span id="order-id" class="font-mono"></span></p>
                <p>Una vez confirmado el pago, comenzaremos a preparar tu pedido</p>
            </div>
        </div>
    </div>

    <script>
        // Variable global para almacenar datos del pedido
        let currentOrderData = null;

        // Obtener order ID de la URL
        const urlParams = new URLSearchParams(window.location.search);
        const orderId = urlParams.get('order');
        if (orderId) {
            const orderIdElement = document.getElementById('order-id');
            if (orderIdElement) {
                orderIdElement.textContent = orderId;
            }
        }

        // Cargar datos del pedido desde la base de datos
        async function loadOrderData() {
            if (!orderId) return;
            
            try {
                const response = await fetch(`/api/get_transfer_order.php?order_id=${orderId}`);
                const data = await response.json();
                
                console.log('API Response:', data);
                if (data.success && data.order) {
                    currentOrderData = data.order;
                    displayOrderItems(data.order.items, data.order.total, data.order.delivery_fee);
                    displayCustomerInfo(data.order);
                    displayDiscounts(data.order);
                } else {
                    console.error('Error cargando pedido:', data.error);
                    const orderItemsElement = document.getElementById('order-items');
                    if (orderItemsElement) {
                        orderItemsElement.innerHTML = '<p class="text-red-500">Error cargando el pedido</p>';
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                const orderItemsElement = document.getElementById('order-items');
                if (orderItemsElement) {
                    orderItemsElement.innerHTML = '<p class="text-red-500">Error cargando el pedido</p>';
                }
            }
        }

        // Mostrar items del pedido
        function displayOrderItems(cart, total, deliveryFee) {
            const orderItemsElement = document.getElementById('order-items');
            const subtotalElement = document.getElementById('subtotal');
            const totalElement = document.getElementById('total');
            const deliveryRowElement = document.getElementById('delivery-row');
            
            if (!orderItemsElement) return;
            
            let itemsHtml = '';
            let subtotal = 0;
            
            cart.forEach(item => {
                let itemTotal = item.price * item.quantity;
                
                if (item.customizations && item.customizations.length > 0) {
                    itemTotal += item.customizations.reduce((sum, c) => sum + (c.price * c.quantity), 0);
                }
                
                subtotal += itemTotal;
                
                let includesText = '';
                
                if (item.customizations && item.customizations.length > 0) {
                    const customItems = item.customizations.map(c => `${c.quantity}x ${c.name} (+$${(c.price * c.quantity).toLocaleString('es-CL')})`).join(', ');
                    includesText = `<div class="text-xs text-blue-600 mt-1">Incluye: ${customItems}</div>`;
                }
                
                const allIncludes = [];
                
                // Agregar productos fijos del combo
                if (item.fixed_items && item.fixed_items.length > 0) {
                    item.fixed_items.forEach(f => {
                        if (typeof f === 'string') {
                            allIncludes.push(f);
                        } else {
                            const fixedItem = f;
                            allIncludes.push(fixedItem.product_name || fixedItem.name || JSON.stringify(f));
                        }
                    });
                }
                
                // Agregar selecciones (bebidas, etc.)
                if (item.selections && typeof item.selections === 'object') {
                    Object.values(item.selections).forEach(categoryItems => {
                        if (Array.isArray(categoryItems)) {
                            categoryItems.forEach(s => {
                                allIncludes.push(s.name || s.product_name || String(s));
                            });
                        } else if (categoryItems && typeof categoryItems === 'object') {
                            // Para selecciones individuales (no arrays)
                            const selection = categoryItems;
                            allIncludes.push(selection['name'] || selection['product_name'] || String(categoryItems));
                        }
                    });
                }
                
                if (allIncludes.length > 0) {
                    if (includesText) {
                        includesText += `<div class="text-xs text-gray-500 mt-1">También: ${allIncludes.join(', ')}</div>`;
                    } else {
                        includesText = `<div class="text-xs text-gray-500 mt-1">Incluye: ${allIncludes.join(', ')}</div>`;
                    }
                }
                
                itemsHtml += `
                    <div class="border-b border-gray-200 pb-2 mb-3 last:border-b-0 last:mb-0">
                        <div class="flex justify-between items-start">
                            <div>
                                <div class="font-medium text-gray-900">${item.name}</div>
                                <div class="text-xs text-gray-500">Cantidad: ${item.quantity}</div>
                                ${includesText}
                            </div>
                            <div class="font-semibold text-gray-900">$${itemTotal.toLocaleString('es-CL')}</div>
                        </div>
                    </div>
                `;
            });
            
            orderItemsElement.innerHTML = itemsHtml;
            
            if (subtotalElement) {
                subtotalElement.textContent = `$${subtotal.toLocaleString('es-CL')}`;
            }
            
            if (totalElement) {
                totalElement.textContent = `$${total.toLocaleString('es-CL')}`;
            }
            
            if (deliveryFee > 0) {
                if (deliveryRowElement) {
                    deliveryRowElement.classList.remove('hidden');
                    deliveryRowElement.classList.add('flex');
                }
                const deliveryFeeElement = document.getElementById('delivery-fee');
                if (deliveryFeeElement) {
                    deliveryFeeElement.textContent = `$${deliveryFee.toLocaleString('es-CL')}`;
                }
            }
        }

        // Mostrar datos del cliente
        function displayCustomerInfo(order) {
            const customerInfoElement = document.getElementById('customer-info');
            const customerNameElement = document.getElementById('customer-name');
            const customerPhoneElement = document.getElementById('customer-phone');
            const deliveryTypeElement = document.getElementById('delivery-type');
            const deliveryAddressElement = document.getElementById('delivery-address');
            const deliveryAddressRowElement = document.getElementById('delivery-address-row');
            
            if (customerNameElement) {
                customerNameElement.textContent = order.customer_name || 'No especificado';
            }
            if (customerPhoneElement) {
                customerPhoneElement.textContent = order.customer_phone || 'No especificado';
            }
            if (deliveryTypeElement) {
                deliveryTypeElement.textContent = order.delivery_type === 'delivery' ? 'Delivery' : 'Retiro';
            }
            
            // Mostrar dirección solo si es delivery
            if (order.delivery_type === 'delivery' && order.delivery_address) {
                if (deliveryAddressElement) {
                    deliveryAddressElement.textContent = order.delivery_address;
                }
                if (deliveryAddressRowElement) {
                    deliveryAddressRowElement.classList.remove('hidden');
                }
            }
            
            if (customerInfoElement) {
                customerInfoElement.classList.remove('hidden');
            }
        }

        function displayDiscounts(order) {
            if (order.discount_10 > 0) {
                document.getElementById('discount-10-row').classList.remove('hidden');
                document.getElementById('discount-10-row').classList.add('flex');
                document.getElementById('discount-10').textContent = `-$${parseInt(order.discount_10).toLocaleString('es-CL')}`;
            }
            if (order.discount_30 > 0) {
                document.getElementById('discount-30-row').classList.remove('hidden');
                document.getElementById('discount-30-row').classList.add('flex');
                document.getElementById('discount-30').textContent = `-$${parseInt(order.discount_30).toLocaleString('es-CL')}`;
            }
            if (order.discount_birthday > 0) {
                document.getElementById('discount-birthday-row').classList.remove('hidden');
                document.getElementById('discount-birthday-row').classList.add('flex');
                document.getElementById('discount-birthday').textContent = `-$${parseInt(order.discount_birthday).toLocaleString('es-CL')}`;
            }
            if (order.discount_pizza > 0) {
                document.getElementById('discount-pizza-row').classList.remove('hidden');
                document.getElementById('discount-pizza-row').classList.add('flex');
                document.getElementById('discount-pizza').textContent = `-$${parseInt(order.discount_pizza).toLocaleString('es-CL')}`;
            }
        }

        // Cargar datos al cargar la página
        document.addEventListener('DOMContentLoaded', loadOrderData);
    </script>
</body>
</html>